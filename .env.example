# Tourni-Kit — Environment Configuration
# Copy this file to .env and fill in your values

# Core App Settings
# -----------------
# Secret key for JWT token signing. Generate a strong random string for production.
# Example: openssl rand -hex 32
SECRET_KEY=change-me-in-production-please

# Public base URL used for invite links and email references
BASE_URL=http://localhost:8001

# Database
# --------
# SQLite is the default. The data directory is volume-mounted in Docker.
DATABASE_URL=sqlite:////app/data/ifak.db

# SMTP Email Configuration
# ------------------------
# Leave SMTP_HOST blank to disable email sending (emails will be logged to console instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
